[global]
    ### Display ###
    # Make notifications follow your mouse across your 3 monitors
    follow = mouse
    width = (300, 500)
    height = (0, 200)
    origin = top-right
    offset = (20, 20)
    scale = 0
    
    # The "Pill" Shape
    corner_radius = 20
    frame_width = 2
    gap_size = 8
    
    # Progress Bar (for volume/brightness)
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_corner_radius = 5

    ### Text ###
    font = JetBrainsMono Nerd Font 11
    line_height = 0
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center

    ### Colors (Catppuccin Mocha) ###
    separator_color = frame
    
[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa" # Blue
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#cba6f7" # Mauve (Your primary accent)
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8" # Red
    timeout = 0
